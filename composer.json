{
    "name": "serventec/i-educar-bis-package",
    "description": "Módulo de Business Intelligence (BI) para geração de relatórios e dashboards no i-Educar",
    "homepage": "https://github.com/serventecieducar/i-educar-powerbi-package",
    "keywords": ["ieducar", "bi", "dashboard", "relatorios", "educacao"],
    "type": "library",
    "authors": [
        {
            "name": "Serventec",
            "email": "contato@serventecassessoria.com.br",
            "homepage": "https://serventecassessoria.com.br"
        },
        {
            "name": "Jader Gabriel",
            "email": "jadergabriel8@gmail.com",
            "homepage": "https://t.me/JaderGabriel"
        }
    ],
    "support": {
        "source": "https://github.com/serventecieducar/i-educar-powerbi-package",
        "issues": "https://github.com/serventecieducar/i-educar-powerbi-package/issues"
    },
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3",
        "consoletvs/charts": "^6.8"
    },
    "require-dev": {
        "laravel/pint": "^1.16",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "iEducar\\Packages\\Bis\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "iEducar\\Packages\\Bis\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "iEducar\\Packages\\Bis\\Providers\\BisProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dex/composer-plug-and-play": true,
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "format": "vendor/bin/pint",
        "test": [
            "@test:phpunit"
        ],
        "test:phpunit": "php ../../../vendor/bin/phpunit -c phpunit.package.xml"
    }
}
